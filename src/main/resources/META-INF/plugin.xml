<idea-plugin url="https://github.com/l2dy/intellij-nginx-plugin">
    <id>io.github.l2dy.ide.ic.nginx</id>
    <name>NGINX Configuration Language</name>
    <version>SNAPSHOT</version>
    <idea-version since-build="233"/>
    <vendor url="https://github.com/l2dy/intellij-nginx-plugin">l2dy</vendor>
    <description><![CDATA[<h4>IDE Plugin for Nginx Configuration Files</h4>
<p>Open source fork of nginx-intellij-plugin, providing support for editing Nginx configuration files.</p>
]]></description>
    <change-notes><![CDATA[
<b>2026.1.11</b>
<ul>
    <li>Forked from <a href="https://github.com/meanmail-dev/nginx-intellij-plugin">meanmail-dev/nginx-intellij-plugin</a> v2026.1.11 (MIT licensed)</li>
</ul>
]]></change-notes>

    <depends>com.intellij.modules.lang</depends>
    <depends optional="true" config-file="lua-support.xml">com.cppcxy.Intellij-EmmyLua</depends>

    <incompatible-with>dev.meanmail.plugin.nginx-intellij-plugin</incompatible-with>
    <incompatible-with>dev.meanmail.plugin.nginx-intellij-plugin-pro</incompatible-with>


    <extensions defaultExtensionNs="com.intellij">
        <fileType implementationClass="dev.meanmail.NginxFileType"
                  language="Nginx Configuration"
                  order="first"
                  name="Nginx Configuration"
                  fileNames="nginx.conf"
                  extensions="conf;nginx"/>
        <completion.contributor language="Nginx Configuration"
                                implementationClass="dev.meanmail.codeInsight.completion.NginxCompletionContributor"/>
        <enterHandlerDelegate
            implementation="dev.meanmail.typing.NginxEnterInLineCommentHandler"
            id="NginxEnterInLineComments"/>
        <enterBetweenBracesDelegate language="Nginx Configuration"
            implementationClass="com.intellij.codeInsight.editorActions.enter.EnterBetweenBracesAndBracketsDelegate"/>
        <localInspection
                language="Nginx Configuration"
                implementationClass="dev.meanmail.codeInsight.inspections.NginxDirectiveInspection"
                displayName="Invalid nginx directive usage"
                groupName="Nginx"
                enabledByDefault="true"
                level="ERROR"
                shortName="NginxDirectiveInspection"/>
        <localInspection
                language="Nginx Configuration"
                implementationClass="dev.meanmail.codeInsight.inspections.NginxGeoInspection"
                displayName="Invalid nginx geo directive usage"
                groupName="Nginx"
                enabledByDefault="true"
                level="ERROR"
                shortName="NginxGeoInspection"/>
        <multiHostInjector implementation="dev.meanmail.lang.injection.NginxLuaInjector"/>
        <backspaceHandlerDelegate
            implementation="dev.meanmail.typing.NginxBraceBackspaceHandler"/>
        <errorHandler implementation="com.intellij.diagnostic.JetBrainsMarketplaceErrorReportSubmitter"/>
        <langCodeStyleSettingsProvider
            implementation="dev.meanmail.codeInsight.formatter.NginxLanguageCodeStyleSettingsProvider"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij.lang">
        <parserDefinition language="Nginx Configuration"
                          implementationClass="dev.meanmail.NginxParserDefinition"/>
        <braceMatcher language="Nginx Configuration"
                      implementationClass="dev.meanmail.typing.NginxBraceMatcher"/>
        <quoteHandler language="Nginx Configuration"
                      implementationClass="dev.meanmail.typing.NginxQuoteHandler"/>
        <syntaxHighlighterFactory language="Nginx Configuration"
                                  implementationClass="dev.meanmail.NginxSyntaxHighlighterFactory"/>
        <psiStructureViewFactory language="Nginx Configuration"
                                 implementationClass="dev.meanmail.structure.NginxStructureViewFactory"/>
        <commenter language="Nginx Configuration"
                   implementationClass="dev.meanmail.NginxCommenter"/>
        <foldingBuilder language="Nginx Configuration"
                        implementationClass="dev.meanmail.folding.NginxFoldingBuilder"/>
        <documentationProvider
                language="Nginx Configuration"
                implementationClass="dev.meanmail.codeInsight.documentation.NginxDocumentationProvider"/>
        <smartEnterProcessor language="Nginx Configuration"
                             implementationClass="dev.meanmail.typing.assist.NginxSmartEnterProcessor"/>
        <formatter language="Nginx Configuration"
                   implementationClass="dev.meanmail.codeInsight.NginxFormattingModelBuilder"/>

    </extensions>

</idea-plugin>
